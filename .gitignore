# Python
__pycache__/
*.py[cod]
*.pyc
*.pyo
.venv/
*.egg-info/
dist/
build/
.eggs/

# Data — ignore scraped outputs and CSVs; commit player profiles and weights
data/**/*.csv
data/**/*.lock
# Keep player JSONs — non-retrievable data (manual types, adjustments, in-house data)
data/**/*.json
!data/**/players/*.json
# Keep pv_weights.json (it's config, not personal data)
!data/**/pv_weights.json

# Test / lint caches
.pytest_cache/
.ruff_cache/
.coverage
coverage.xml

# IDE / OS
.DS_Store
.idea/
.vscode/
*.swp

# Logs
*.log

# Secrets
.env
*.env
config/credentials.json
config/token.json

# Test / diag outputs
tests/diag/fixtures/
